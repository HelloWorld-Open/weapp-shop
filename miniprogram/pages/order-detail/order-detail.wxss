.page {
  background: #f5f0eb;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.status-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.status-section::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.status-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
  animation: pulse 2s ease infinite;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  position: relative;
  z-index: 1;
}

.status-order-no {
  font-size: 24rpx;
  margin-top: 12rpx;
  opacity: 0.8;
  position: relative;
  z-index: 1;
}

.address-section {
  background: #faf6f2;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
}

.address-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #6c6c7a;
}

.items-section {
  background: #fff;
  padding: 20rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  flex-shrink: 0;
  border: 2rpx solid rgba(0,0,0,0.04);
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 26rpx;
  color: #1a1a2e;
  display: block;
}

.item-price {
  font-size: 24rpx;
  color: #6a6a6a;
  margin-top: 8rpx;
  display: block;
}

.item-total {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: bold;
}

.info-section {
  background: #fff;
  padding: 20rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #6a6a6a;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a2e;
}

.discount-value {
  font-size: 26rpx;
  color: #2ed573;
  font-weight: 600;
}

.final-row {
  border-top: 1rpx solid #f0ece6;
  padding-top: 20rpx;
  margin-top: 12rpx;
}

.final-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.final-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

.total-row {
  border-top: 1rpx solid #f0ece6;
  padding-top: 20rpx;
  margin-top: 12rpx;
}

.total-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  background: #ffffff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8e2dc;
  justify-content: flex-end;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.04);
}

.action-btn {
  padding: 18rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: transform 0.15s;
}

.action-btn.hover {
  transform: scale(0.96);
}

.cancel-btn {
  background: #fff;
  color: #6c6c7a;
  border: 2rpx solid #8a8a8a;
}

.pay-btn {
  background: linear-gradient(135deg, #ff4757, #ff6348);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255,71,87,0.25);
}

.confirm-btn {
  background: linear-gradient(135deg, #2ed573, #7bed9f);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(46,213,115,0.25);
}

.review-btn {
  background: linear-gradient(135deg, #ffa502, #ff6348);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255,165,2,0.25);
}

.reviewed-btn {
  background: #f0ece6;
  color: #6a6a6a;
}

.refund-btn {
  background: #fff;
  color: #ff4757;
  border: 2rpx solid #ff4757;
}

.refund-btn.hover {
  background: #fff5f5;
}

.refunded-btn {
  background: #f0ece6;
  color: #6a6a6a;
}

.loading {
  padding: 200rpx 0;
  text-align: center;
  color: #6a6a6a;
}
