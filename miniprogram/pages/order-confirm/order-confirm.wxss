.page {
  background: #f5f0eb;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.address-section {
  display: flex;
  align-items: center;
  background: #faf6f2;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.address-phone {
  font-size: 26rpx;
  color: #6c6c7a;
}

.address-detail {
  font-size: 24rpx;
  color: #6a6a6a;
}

.address-empty {
  flex: 1;
  font-size: 28rpx;
  color: #6a6a6a;
}

.address-arrow {
  font-size: 36rpx;
  color: #8a8a8a;
}

.items-section {
  background: #fff;
  padding: 20rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  flex-shrink: 0;
  border: 2rpx solid rgba(0,0,0,0.04);
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 26rpx;
  color: #1a1a2e;
  display: block;
}

.item-price {
  font-size: 24rpx;
  color: #6a6a6a;
  margin-top: 8rpx;
  display: block;
}

.item-total {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: bold;
}

.remark-section {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.remark-label {
  font-size: 26rpx;
  color: #1a1a2e;
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.remark-input {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a2e;
}

.total-display {
  flex: 1;
  font-size: 26rpx;
  color: #1a1a2e;
}

.total-amount {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4757;
}

.submit-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #ff4757, #ff6348);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255,71,87,0.25);
  transition: transform 0.15s, box-shadow 0.15s;
}

.submit-btn.hover {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(255,71,87,0.15);
}

.coupon-section {
  background: #fff;
  padding: 24rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  transition: background 0.2s;
}
.coupon-section.hover {
  background: #faf6f2;
}
.coupon-label {
  font-size: 26rpx;
  color: #1a1a2e;
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}
.coupon-trigger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.coupon-trigger-text {
  font-size: 26rpx;
  color: #8a8a8a;
}
.coupon-trigger-text.selected {
  color: #ff4757;
  font-weight: 500;
}
.coupon-arrow { font-size: 36rpx; color: #8a8a8a; margin-left: auto; margin-left: 12rpx; }

.coupon-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
  transition: opacity 0.3s;
}
.coupon-picker {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}
.coupon-picker.show {
  transform: translateY(0);
}
.coupon-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0ece6;
  flex-shrink: 0;
}
.coupon-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.coupon-picker-close {
  font-size: 28rpx;
  color: #8a8a8a;
  padding: 10rpx;
}
.coupon-picker-list {
  flex: 1;
  overflow-y: auto;
  padding: 10rpx 0;
}
.coupon-picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f0eb;
  transition: background 0.15s;
}
.coupon-picker-item.active {
  background: #fff5f5;
}
.coupon-picker-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #d0d0d0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: border-color 0.2s;
}
.coupon-picker-item.active .coupon-picker-radio {
  border-color: #ff4757;
}
.coupon-picker-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: transparent;
  transition: background 0.2s;
}
.coupon-picker-dot.filled {
  background: #ff4757;
}
.coupon-picker-item-info {
  flex: 1;
}
.coupon-picker-item-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
  display: block;
}
.coupon-picker-item-limit {
  font-size: 22rpx;
  color: #6a6a6a;
  margin-top: 4rpx;
  display: block;
}
.coupon-picker-item-save {
  font-size: 22rpx;
  color: #2ed573;
  font-weight: 500;
  flex-shrink: 0;
}
.coupon-picker-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0ece6;
  flex-shrink: 0;
}
.coupon-picker-clear {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 40rpx;
  border: 2rpx solid #8a8a8a;
  font-size: 28rpx;
  color: #6a6a6a;
  font-weight: 500;
}
.coupon-picker-confirm {
  flex: 2;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #ff4757, #ff6348);
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255,71,87,0.25);
}

.total-label {
  font-size: 26rpx;
  color: #1a1a2e;
}

.total-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4757;
}

.total-section {
  background: #fff;
  padding: 24rpx 30rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e8e2dc;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.total-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.total-discount {
  font-size: 26rpx;
  color: #2ed573;
  font-weight: 600;
}
