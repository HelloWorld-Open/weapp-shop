.page {
  display: flex;
  height: 100vh;
  background: #f5f0eb;
}

.sidebar {
  display: flex;
  flex-direction: column;
  width: 180rpx;
  background: #faf6f2;
  height: 100vh;
  overflow-y: auto;
}

.sidebar-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 34rpx 20rpx;
  font-size: 26rpx;
  color: #6c6c7a;
  text-align: center;
  border-left: 4rpx solid transparent;
  transition: all 0.2s;
  font-weight: 500;
}

.sidebar-item.active {
  background: #f5f0eb;
  color: #c97b63;
  font-weight: 600;
  border-left-color: #c97b63;
  box-shadow: inset 0 0 20rpx rgba(201,123,99,0.06);
}

.content {
  flex: 1;
  padding: 20rpx;
  height: 100vh;
  background: #f5f0eb;
}

.section-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 4rpx 16rpx;
}

.section-cat-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.section-count {
  font-size: 24rpx;
  color: #6a6a6a;
}

.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.product-item {
  background: #faf6f2;
  border-radius: 16rpx;
  overflow: hidden;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.product-item.hover {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.10), 0 20rpx 60rpx rgba(0,0,0,0.08);
}

.product-image {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  border-bottom: 2rpx solid rgba(0,0,0,0.04);
}

.product-info {
  padding: 14rpx 16rpx 18rpx;
}

.product-name {
  font-size: 24rpx;
  color: #1a1a2e;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
}

.product-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #c97b63;
  margin-top: 8rpx;
  display: block;
}

.sk-cat-img {
  height: 240rpx;
  border-radius: 16rpx 16rpx 0 0;
}

.sk-cat-line {
  height: 24rpx;
  border-radius: 6rpx;
  margin: 0 12rpx;
}

.sk-cat-line-sm {
  height: 24rpx;
  width: 50%;
  border-radius: 6rpx;
  margin: 8rpx 12rpx 14rpx;
}
