.page {
  background: #f5f0eb;
  min-height: 100vh;
}

.list {
  padding: 20rpx;
}

.list-item {
  margin-bottom: 20rpx;
}

.item {
  background: #faf6f2;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  display: flex;
  padding: 20rpx;
  gap: 20rpx;
}

.item-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
}

.item-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4757;
}

.item-stock {
  font-size: 22rpx;
  color: #6a6a6a;
}

.item-sales {
  font-size: 22rpx;
  color: #6a6a6a;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  justify-content: center;
  flex-shrink: 0;
}

.cart-btn {
  padding: 8rpx 20rpx;
  background: #c97b63;
  color: #fff;
  font-size: 22rpx;
  border-radius: 24rpx;
  text-align: center;
  font-weight: 500;
}

.cart-btn.hover {
  opacity: 0.8;
}

.del-btn {
  padding: 8rpx 20rpx;
  background: #faf6f2;
  color: #6a6a6a;
  font-size: 22rpx;
  border-radius: 24rpx;
  text-align: center;
  border: 2rpx solid #e8e2dc;
}

.del-btn.hover {
  background: #ffecec;
  color: #ff4757;
  border-color: #ffd4d4;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #6a6a6a;
  font-size: 24rpx;
}