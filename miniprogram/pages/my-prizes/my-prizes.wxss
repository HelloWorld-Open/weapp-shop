.page { height: 100vh; background: #f5f0eb }
.list-wrap { height: 100%; padding: 20rpx }

.prize-card { display: flex; background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06); animation: fadeIn 0.35s ease both }
.prize-img { width: 140rpx; height: 140rpx; border-radius: 14rpx; flex-shrink: 0; background: #f0ece6; margin-right: 20rpx }
.prize-info { flex: 1; display: flex; flex-direction: column; justify-content: center }
.prize-name { font-size: 28rpx; font-weight: 600; color: #1a1a2e }
.prize-time { font-size: 22rpx; color: #8a8a8a; margin-top: 8rpx }
.prize-status { display: inline-block; align-self: flex-start; margin-top: 12rpx; padding: 6rpx 20rpx; background: #fff0f0; color: #ff4757; border-radius: 20rpx; font-size: 22rpx; font-weight: 500 }

.load-more { text-align: center; padding: 30rpx; color: #6c6c7a; font-size: 24rpx }
