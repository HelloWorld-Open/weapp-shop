.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f0eb;
}

.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 20rpx;
  border-bottom: 1rpx solid #e8e2dc;
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 26rpx;
  color: #6c6c7a;
  position: relative;
  transition: color 0.2s;
}

.tab.active {
  color: #ff4757;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #ff4757;
  border-radius: 2rpx;
}

.order-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

.order-card {
  background: #faf6f2;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.order-card.hover {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.10), 0 20rpx 60rpx rgba(0,0,0,0.08);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 24rpx;
  color: #6a6a6a;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-items {
  border-top: 1rpx solid #f0ece6;
  padding-top: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.order-item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  flex-shrink: 0;
  border: 2rpx solid rgba(0,0,0,0.04);
}

.order-item-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-item-name {
  font-size: 26rpx;
  color: #1a1a2e;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-item-qty {
  font-size: 24rpx;
  color: #6a6a6a;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0ece6;
}

.order-time {
  font-size: 22rpx;
  color: #6a6a6a;
}

.order-total {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: bold;
}
