.page {
  background: #f5f0eb;
  min-height: 100vh;
  padding: 20rpx;
}

.product-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #faf6f2;
  padding: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0ece6;
  flex-shrink: 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.4;
  flex: 1;
}

.rating-section, .content-section, .image-section {
  background: #faf6f2;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 26rpx;
  color: #6c6c7a;
  display: block;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.stars {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  padding: 10rpx 0;
}

.star {
  font-size: 60rpx;
  color: #e8e2dc;
  transition: transform 0.2s, color 0.2s;
}

.star.hover {
  transform: scale(1.3);
}

.star.active {
  color: #ffa502;
}

.content-input {
  width: 100%;
  height: 200rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #e8e2dc;
}

.content-input::placeholder {
  color: #8a8a8a;
}

.word-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #6a6a6a;
  margin-top: 8rpx;
}

.image-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.uploaded-img {
  width: 100%;
  height: 100%;
  background: #f0ece6;
}

.del-img {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 20rpx;
}

.add-btn {
  border: 2rpx dashed #e8e2dc;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.add-btn.hover {
  background: #f5f0eb;
}

.add-icon {
  font-size: 48rpx;
  color: #8a8a8a;
}

.submit-section {
  padding: 20rpx 0 40rpx;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff4757, #ff6348);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(255,71,87,0.25);
}

.submit-btn.hover {
  transform: scale(0.97);
}

.submit-btn.disabled {
  background: #8a8a8a;
  box-shadow: none;
}
