.product-card {
  position: relative;
  background: #faf6f2;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
}

.product-card.hover {
  transform: translateY(-6rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.10), 0 20rpx 60rpx rgba(0,0,0,0.08);
}

.product-image {
  width: 100%;
  height: 340rpx;
  background: linear-gradient(135deg, #f0ece6 0%, #e8e2dc 100%);
  border-bottom: 2rpx solid rgba(0,0,0,0.04);
}

.favorite-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.3s ease;
  z-index: 2;
}

.favorite-btn.hover {
  transform: scale(1.2);
}

.favorite-btn.active {
  background: rgba(255,255,255,0.95);
}

.heart-icon {
  font-size: 28rpx;
  line-height: 1;
}

.product-info {
  padding: 16rpx 20rpx 22rpx;
}

.product-name {
  font-size: 26rpx;
  color: #1a1a2e;
  line-height: 1.4;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
}

.highlight {
  color: #b8654c;
  font-weight: 700;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff4757;
  letter-spacing: 0.5rpx;
}

.product-original-price {
  font-size: 22rpx;
  color: #6a6a6a;
  text-decoration: line-through;
  margin-left: 10rpx;
}

.product-sales {
  font-size: 22rpx;
  color: #6a6a6a;
  margin-top: 8rpx;
  display: block;
}
