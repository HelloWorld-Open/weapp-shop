/* ======= 全局 ======= */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a2e;
  background-color: #f5f0eb;
  box-sizing: border-box;
}

view, scroll-view, swiper, movable-area, cover-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
}

button::after {
  border: none;
}

image {
  width: 100%;
  height: 100%;
}

/* ======= 卡片公共样式 ======= */
.card {
  background: #faf6f2;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08), 0 12rpx 40rpx rgba(0,0,0,0.06);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
}

.card.hover {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.10), 0 20rpx 60rpx rgba(0,0,0,0.08);
}

/* ======= 输入框公共样式 ======= */
.input-field {
  height: 72rpx;
  padding: 0 28rpx;
  background: #efe9e4;
  border-radius: 36rpx;
  font-size: 26rpx;
  color: #1a1a2e;
  transition: box-shadow 0.2s, background 0.2s;
}

.input-field:focus {
  background: #ffffff;
  box-shadow: 0 0 0 3rpx rgba(255,71,87,0.12);
}

.input-field::placeholder {
  color: #b0aaa4;
}

/* ======= 按钮公共样式 ======= */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #ff4757, #ff6348);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255,71,87,0.25);
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
}

.btn-primary.hover {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(255,71,87,0.15);
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  background: #ffffff;
  color: #ff4757;
  border: 2rpx solid #ff4757;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease;
}

.btn-outline.hover {
  transform: scale(0.95);
  background: #fff5f5;
}

/* ======= 底部操作栏 ======= */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e8e2dc;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.04);
  gap: 16rpx;
  z-index: 50;
}

/* ======= 全局动画 ======= */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx) }
  to   { opacity: 1; transform: translateY(0) }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx) }
  to   { opacity: 1; transform: translateY(0) }
}
@keyframes skeleton {
  0%   { background-position: 100% 50% }
  100% { background-position: -100% 50% }
}
@keyframes ripple {
  to { transform: scale(4); opacity: 0 }
}
@keyframes elasticIn {
  0%   { transform: scale(0.3); opacity: 0 }
  50%  { transform: scale(1.05) }
  70%  { transform: scale(0.95) }
  100% { transform: scale(1); opacity: 1 }
}
@keyframes shake {
  0%, 100% { transform: translateX(0) }
  20%      { transform: translateX(-12rpx) }
  40%      { transform: translateX(12rpx) }
  60%      { transform: translateX(-8rpx) }
  80%      { transform: translateX(8rpx) }
}
@keyframes spin {
  to { transform: rotate(360deg) }
}
@keyframes pulse {
  0%, 100% { opacity: 1 }
  50% { opacity: 0.5 }
}
@keyframes imgFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx) }
  to   { opacity: 1; transform: translateY(0) }
}

.fade-in {
  animation: fadeIn 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}
.fade-in-up {
  animation: fadeInUp 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}
.slide-up {
  animation: slideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}
.img-fade-in {
  animation: imgFadeIn 0.3s ease both;
}
.delay-1 { animation-delay: 0.1s }
.delay-2 { animation-delay: 0.2s }
.delay-3 { animation-delay: 0.3s }
.delay-4 { animation-delay: 0.4s }
.delay-5 { animation-delay: 0.5s }

/* ======= 骨架屏 ======= */
.skeleton {
  background: linear-gradient(90deg, #e8e2dc 25%, #f0ece6 37%, #e8e2dc 63%);
  background-size: 200% 100%;
  animation: skeleton 1.5s ease infinite;
  border-radius: 8rpx;
}

.skeleton-block {
  height: 200rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.skeleton-line {
  height: 28rpx;
  margin-bottom: 16rpx;
  width: 100%;
}

.skeleton-line-sm {
  height: 28rpx;
  width: 60%;
  margin-bottom: 16rpx;
}

.page-skeleton {
  padding: 30rpx;
}

/* ======= 按钮涟漪 ======= */
.ripple-btn {
  position: relative;
  overflow: hidden;
  cursor: pointer;
}

.ripple-btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  transform: translate(-50%,-50%) scale(0);
}

.ripple-btn.hover::after {
  animation: ripple 0.6s ease-out;
}

/* ======= 加载更多 ======= */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #6a6a6a;
  font-size: 26rpx;
}

/* ======= 空状态 ======= */
.empty-wrap {
  padding: 120rpx 40rpx;
  text-align: center;
}
